{
    "version": 1,
    "disable_existing_loggers": false,
  
    "formatters": {
        "standard": {
            "format": "%(asctime)s | %(processName)s | %(levelname)s | %(name)s | %(message)s"
        }
    },
  
    "handlers": {
        "console": {
            "class": "logging.StreamHandler",
            "level": "INFO",
            "formatter": "standard",
            "stream": "ext://sys.stdout"
        },
        "file_per_process": {
            "class": "logging.FileHandler",
            "level": "DEBUG",
            "formatter": "standard",
            "filename": "__PROCESS_LOG_FILE__",
            "mode": "a"
        }
    },
  
    "root": {
        "level": "DEBUG",
        "handlers": ["console", "file_per_process"]
    }
}
  